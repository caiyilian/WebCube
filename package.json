{
  "name": "webcube",
  "version": "1.0.0",
  "description": "WebCube - 网页版魔方游戏，支持多人联机、协作解魔方、AI 智能提示",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:client": "vitest run --dir src",
    "test:server": "vitest run --dir server"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caiyilian/WebCube.git"
  },
  "keywords": [
    "rubiks-cube",
    "three.js",
    "typescript",
    "multiplayer"
  ],
  "author": "caiyilian",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/caiyilian/WebCube/issues"
  },
  "homepage": "https://github.com/caiyilian/WebCube#readme",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/socket.io": "^3.0.1",
    "cubejs": "^1.3.2",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@types/three": "^0.185.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "main": "index.js"
}
