{
  "name": "webcube",
  "version": "1.0.0",
  "description": "WebCube - 网页版魔方游戏，支持多人联机、协作解魔方、AI 智能提示",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:client": "vitest run --dir src",
    "test:server": "vitest run --dir server",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "build:electron": "tsc -p electron/tsconfig.json",
    "generate-icon": "tsx scripts/generate-icon.ts",
    "electron:dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && npm run build:electron && electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caiyilian/WebCube.git"
  },
  "keywords": [
    "rubiks-cube",
    "three.js",
    "typescript",
    "multiplayer"
  ],
  "author": "caiyilian",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/caiyilian/WebCube/issues"
  },
  "homepage": "https://github.com/caiyilian/WebCube#readme",
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/socket.io": "^3.0.1",
    "cubejs": "^1.3.2",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/three": "^0.185.0",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "main": "dist-electron/main.js"
}
